{
  "name": "@lawrence/platform",
  "version": "0.0.0",
  "private": true,
  "description": "LAWRENCE Platform — Phase 0 Foundation / Contract Freeze. Durable by frozen contracts, not implementations.",
  "packageManager": "pnpm@10.34.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "turbo run lint && pnpm lint:arch",
    "lint:arch": "depcruise packages --config .dependency-cruiser.cjs",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "build": "turbo run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@changesets/cli": "2.27.9",
    "@eslint/js": "9.14.0",
    "@playwright/test": "1.48.2",
    "@types/node": "22.9.0",
    "dependency-cruiser": "16.5.0",
    "eslint": "9.14.0",
    "eslint-config-prettier": "9.1.0",
    "prettier": "3.3.3",
    "turbo": "2.3.0",
    "typescript": "5.6.3",
    "typescript-eslint": "8.14.0",
    "vitest": "2.1.5"
  }
}
