# Phase 9 — example PRODUCTION environment (NO REAL SECRETS). Use a secret manager.
# DATABASE_URL is REQUIRED in production (NODE_ENV=production); the in-memory
# store is not durable. Set LAWRENCE_ALLOW_MEMORY_STORE=1 only to knowingly
# accept the ephemeral store (not recommended).
DATABASE_URL=postgres://USER:REF@HOST:5432/lawrence
# Connection pool tuning (optional; defaults shown).
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_MS=30000
DATABASE_POOL_CONNECT_MS=10000
APP_BASE_URL=https://lawrence.example.com
ENCRYPTION_KEY=set-via-secret-manager
OPENAI_API_KEY=set-via-secret-manager
ANTHROPIC_API_KEY=set-via-secret-manager
SLACK_WEBHOOK_URL=set-via-secret-manager
RESEND_API_KEY=set-via-secret-manager
LAWRENCE_EMAIL_FROM=alerts@example.com
STORAGE_PROVIDER=s3
STORAGE_BUCKET=lawrence-prod
VECTOR_PROVIDER=builtin
DEFAULT_MODEL_CHAT=claude-opus-4-8
DEFAULT_MODEL_EMBEDDING=text-embedding-3-large
