# Phase 9 — example environment (NO REAL SECRETS). Copy to .env.local.
DATABASE_URL=
APP_BASE_URL=http://localhost:3000
ENCRYPTION_KEY=dev-only-change-me
# Model providers (omit to use the deterministic mock with LAWRENCE_ALLOW_MOCK_MODEL=1)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LAWRENCE_ALLOW_MOCK_MODEL=1
# External notification channels (optional)
SLACK_WEBHOOK_URL=
LAWRENCE_SLACK_ENABLED=
RESEND_API_KEY=
LAWRENCE_EMAIL_FROM=
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
# Storage / vector
STORAGE_PROVIDER=local
STORAGE_BUCKET=
VECTOR_PROVIDER=builtin
# Default models
DEFAULT_MODEL_CHAT=claude-opus-4-8
DEFAULT_MODEL_EMBEDDING=text-embedding-3-large
