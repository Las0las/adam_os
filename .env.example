# Phase 9 — example environment (NO REAL SECRETS). Copy to .env.local.
DATABASE_URL=
# Required in production. Override to accept the ephemeral in-memory store:
# LAWRENCE_ALLOW_MEMORY_STORE=1
# Row-level security (two-role model): when the app connects as a non-owner role
# whose tables are provisioned ahead of time, skip lazy DDL:
# LAWRENCE_DB_MANAGED_SCHEMA=1
# Used only by scripts/setup-runtime-rls.ts (run as the privileged owner) to
# grant the runtime app role: LAWRENCE_DB_APP_ROLE=lawrence_app
# Suppress the destructive demo seed even on the in-memory backend:
# LAWRENCE_DISABLE_DEMO_SEED=1
# Connection pool tuning (optional): DATABASE_POOL_MAX / DATABASE_POOL_IDLE_MS / DATABASE_POOL_CONNECT_MS
APP_BASE_URL=http://localhost:3000
ENCRYPTION_KEY=dev-only-change-me
# Authentication (Clerk). Required in production; omit in dev to run unauthenticated.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Accept the demo system actor instead of real auth (dev/demo only):
# LAWRENCE_ALLOW_DEMO_AUTH=1
# Single-tenant deployments map all users to this tenant (default: demo tenant):
# LAWRENCE_DEFAULT_TENANT_ID=
# Agent runtime resource governance (per-run bounds; defaults shown):
# LAWRENCE_AGENT_MAX_STEPS=50
# LAWRENCE_AGENT_TIMEOUT_MS=60000
# LAWRENCE_AGENT_MAX_FUNCTION_CALLS=20
# Model providers (omit to use the deterministic mock with LAWRENCE_ALLOW_MOCK_MODEL=1)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LAWRENCE_ALLOW_MOCK_MODEL=1
# External notification channels (optional)
SLACK_WEBHOOK_URL=
LAWRENCE_SLACK_ENABLED=
RESEND_API_KEY=
LAWRENCE_EMAIL_FROM=
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
# Observability export (optional). Structured JSON logs always go to stdout
# (LAWRENCE_LOG_LEVEL=debug|info|warn|error, default info) for an OTel Collector /
# log aggregator to ingest. Set SENTRY_DSN to additionally export errors to Sentry.
LAWRENCE_LOG_LEVEL=info
SENTRY_DSN=
# LAWRENCE_RELEASE=  # optional release tag attached to exported events
# Storage / vector
STORAGE_PROVIDER=local
STORAGE_BUCKET=
VECTOR_PROVIDER=builtin
# Default models
DEFAULT_MODEL_CHAT=claude-opus-4-8
DEFAULT_MODEL_EMBEDDING=text-embedding-3-large
